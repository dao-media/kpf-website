{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kpf/button",
  "version": "0.1.0",
  "title": "Foundation Button",
  "category": "kpf-components",
  "icon": "button",
  "description": "A reusable call-to-action link with editable text and appearance.",
  "keywords": ["button", "link", "action"],
  "textdomain": "kpf-core",
  "attributes": {
    "text": {
      "type": "string",
      "source": "html",
      "selector": ".kpf-button__label",
      "default": "Learn more"
    },
    "url": {
      "type": "string",
      "default": ""
    },
    "opensInNewTab": {
      "type": "boolean",
      "default": false
    },
    "variant": {
      "type": "string",
      "default": "primary"
    },
    "size": {
      "type": "string",
      "default": "medium"
    },
    "alignment": {
      "type": "string",
      "default": "left"
    }
  },
  "supports": {
    "html": false,
    "reusable": true,
    "className": false
  }
}
